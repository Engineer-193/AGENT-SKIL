# ============================================
# WAJIB — 2 variabel ini HARUS diisi
# ============================================

# Token bot Telegram → dapatkan dari @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# API Key DeepSeek → daftar di platform.deepseek.com → API Keys
OPENAI_API_KEY=your_deepseek_api_key

# ============================================
# OPSIONAL — bisa dibiarkan, sudah ada default
# ============================================

# Jangan diubah (endpoint DeepSeek)
OPENAI_BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=deepseek-chat

# ID Telegram yang boleh chat bot (kosongkan = semua orang bisa)
# Cara cek ID kamu: kirim pesan ke @userinfobot di Telegram
ALLOWED_USER_IDS=
ADMIN_USER_IDS=
